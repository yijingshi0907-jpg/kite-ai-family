generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum SigningStatus {
  PENDING_REVIEW
  SENT
  IN_PROGRESS
  COMPLETED
  DECLINED
  EXPIRED
}

enum DocumentSource {
  GMAIL
  SLACK
  GOOGLE_DRIVE
  MANUAL
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  image         String?
  googleToken   String?
  googleRefresh String?
  slackToken    String?
  slackTeamId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  signingRequests SigningRequest[]
  detectedDocs    DetectedDocument[]
  settings        UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  slackChannelId     String?
  slackChannelName   String?
  driveMonitorFolder String?
  keywordsList       String[] @default(["sign", "contract", "agreement"])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DetectedDocument {
  id         String         @id @default(cuid())
  userId     String
  source     DocumentSource
  sourceId   String
  fileName   String
  fileUrl    String?
  subject    String?
  detectedAt DateTime       @default(now())
  reviewed   Boolean        @default(false)
  dismissed  Boolean        @default(false)

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  signingRequest SigningRequest?

  @@unique([userId, source, sourceId])
}

model SigningRequest {
  id             String        @id @default(cuid())
  userId         String
  detectedDocId  String?       @unique
  documentName   String
  dropboxSignId  String?       @unique
  signingUrl     String?
  slackMessageTs String?
  status         SigningStatus  @default(SENT)
  signers        Json
  sentAt         DateTime      @default(now())
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  detectedDoc DetectedDocument? @relation(fields: [detectedDocId], references: [id])
  events      SigningEvent[]
}

model SigningEvent {
  id               String   @id @default(cuid())
  signingRequestId String
  eventType        String
  signerEmail      String?
  occurredAt       DateTime @default(now())
  metadata         Json?

  signingRequest SigningRequest @relation(fields: [signingRequestId], references: [id], onDelete: Cascade)
}
