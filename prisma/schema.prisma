generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum SigningStatus {
  PENDING_REVIEW
  SENT
  IN_PROGRESS
  COMPLETED
  DECLINED
  EXPIRED
}

enum DocumentSource {
  GMAIL
  SLACK
  GOOGLE_DRIVE
  MANUAL
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  googleToken     String?
  googleRefresh   String?
  slackToken      String?
  slackTeamId     String?
  dropboxToken    String?
  dropboxRefresh  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  signingRequests SigningRequest[]
  detectedDocs    DetectedDocument[]
  settings        UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  slackChannelIds           String[] @default([])
  driveMonitorFolder        String?
  keywordsList              String[] @default(["sign", "contract", "agreement"])
  dropboxSignFolder         String?
  dropboxSignRequesterEmail String?
  dropboxSignCcEmail        String?
  dropboxSaveFolder         String?   // Dropbox storage folder path for saving signed docs
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DetectedDocument {
  id         String         @id @default(cuid())
  userId     String
  source     DocumentSource
  sourceId   String
  fileName   String
  fileUrl    String?
  subject    String?
  detectedAt DateTime       @default(now())
  reviewed   Boolean        @default(false)
  dismissed  Boolean        @default(false)

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  signingRequest SigningRequest?

  @@unique([userId, source, sourceId])
}

model SigningRequest {
  id             String        @id @default(cuid())
  userId         String
  detectedDocId  String?       @unique
  documentName   String
  dropboxSignId  String?       @unique
  signingUrl     String?
  slackMessageTs String?
  status         SigningStatus  @default(SENT)
  signers        Json
  sentAt         DateTime      @default(now())
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  detectedDoc DetectedDocument? @relation(fields: [detectedDocId], references: [id])
  events      SigningEvent[]
}

model SigningEvent {
  id               String   @id @default(cuid())
  signingRequestId String
  eventType        String
  signerEmail      String?
  occurredAt       DateTime @default(now())
  metadata         Json?

  signingRequest SigningRequest @relation(fields: [signingRequestId], references: [id], onDelete: Cascade)
}

// ── Family site content ──────────────────────────────────────────────────────

model FamilyWeeklyPost {
  id          String   @id @default(cuid())
  weekOf      String   // e.g. "2026-06-15"
  weekLabel   String   // e.g. "2026 年 6 月 15 日 当周"
  date        String   // e.g. "2026-06-18"
  textZh      String
  summaryZh   String?  // 1-2 sentence summary for display
  url         String
  mediaUrl    String?  // original URL (YouTube thumbnail or tweet image)
  likes       Int?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model FamilyInterview {
  id        String   @id @default(cuid())
  date      String
  titleZh   String
  bodyZh    String
  type      String   @default("interview") // "interview" | "podcast"
  youtubeId String?
  imageUrl  String?
  sourceUrl String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model FamilyNewsArticle {
  id          String   @id @default(cuid())
  date        String
  titleZh     String?
  titleEn     String
  descZh      String?
  publisher   String
  url         String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model FamilyPodcast {
  id         String   @id @default(cuid())
  episode    Int
  titleZh    String
  guestZh    String
  guestOrgZh String
  youtubeUrl String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
}

model FamilyRefLink {
  id       String   @id @default(cuid())
  icon     String
  titleZh  String
  descZh   String
  url      String
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
}
